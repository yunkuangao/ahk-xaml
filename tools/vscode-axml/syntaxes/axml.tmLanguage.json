{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "AXML",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#templates"
    },
    {
      "include": "#events"
    },
    {
      "include": "#properties"
    },
    {
      "include": "#elements"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "match": "#.*$",
          "name": "comment.line.number-sign.axml"
        }
      ]
    },
    "templates": {
      "patterns": [
        {
          "match": "^\\s*(@Template)\\s+([a-zA-Z0-9_\\.]+)(?:\\s*\\(([^)]+)\\))?\\s*:",
          "captures": {
            "1": {
              "name": "keyword.control.template.axml"
            },
            "2": {
              "name": "entity.name.type.class.axml"
            },
            "3": {
              "name": "variable.other.constant.axml"
            }
          }
        }
      ]
    },
    "elements": {
      "patterns": [
        {
          "match": "^\\s*([a-zA-Z0-9_\\.]+)(?:\\s*\\(([^)]+)\\))?\\s*:\\s*$",
          "captures": {
            "1": {
              "name": "entity.name.tag.axml"
            },
            "2": {
              "name": "entity.name.function.axml"
            }
          }
        }
      ]
    },
    "events": {
      "patterns": [
        {
          "match": "^\\s*(On[a-zA-Z0-9_]+)\\s*:\\s*(\\S.*)$",
          "captures": {
            "1": {
              "name": "keyword.control.axml"
            },
            "2": {
              "patterns": [
                {
                  "include": "#values"
                }
              ]
            }
          }
        }
      ]
    },
    "properties": {
      "patterns": [
        {
          "match": "^\\s*([a-zA-Z0-9_\\.]+)\\s*:\\s*(\\S.*)$",
          "captures": {
            "1": {
              "name": "entity.other.attribute-name.axml"
            },
            "2": {
              "patterns": [
                {
                  "include": "#values"
                }
              ]
            }
          }
        }
      ]
    },
    "values": {
      "patterns": [
        {
          "match": "\\$([a-zA-Z0-9_]+)",
          "name": "variable.other.readwrite.axml"
        },
        {
          "match": "=>.*$",
          "name": "meta.function.inline.ahk2.axml",
          "captures": {
            "0": {
              "name": "source.ahk2"
            }
          }
        },
        {
          "match": "\\b(True|False|true|false)\\b",
          "name": "constant.language.boolean.axml"
        },
        {
          "match": "\\b[0-9]+(?:\\.[0-9]+)?\\b",
          "name": "constant.numeric.axml"
        },
        {
          "begin": "\"",
          "end": "\"",
          "name": "string.quoted.double.axml",
          "patterns": [
            {
              "match": "\\{\\s*DynamicResource\\s+([a-zA-Z0-9_]+)\\s*\\}",
              "captures": {
                "0": {
                  "name": "keyword.other.dynamic-resource.axml"
                },
                "1": {
                  "name": "variable.other.resource.axml"
                }
              }
            },
            {
              "match": "\\{\\{([a-zA-Z0-9_]+)\\}\\}",
              "name": "variable.other.template.axml"
            }
          ]
        }
      ]
    }
  },
  "scopeName": "source.axml"
}
