Window:
  Title: "AXML Error Engine Test"
  Width: 400
  Height: 300

  Grid:
    Rows: "*", "Auto", "*"
    
    TextBlock:
      Grid_Row: 0
      Text: "This AXML file has an error below!"
      FontSize: 16
      HorizontalAlignment: "Center"
      VerticalAlignment: "Bottom"
      Margin: "10"
      
    # This property doesn't exist and will crash WPF!
    Button (BtnTest):
      Grid_Row: 1
      Content: "Crash Me!"
      TotallyFakeProperty: "ThisWillCrash!"
      Padding: "20,10,20,10"
      HorizontalAlignment: "Center"
      Margin: "0,20,0,0"
      
    # Uncomment the line below to test AXML Syntax Error instead of WPF Error
    # Margin="20"
